{
  "info": {
    "name": "Strapi CMS API",
    "description": "REST CRUD for Strapi collection types: dishes, restaurants, chefs, tags. You will get 403 until Settings → Users & Permissions → Roles grants access for the `find` / `findOne` / `create` / `update` / `delete` actions, or you use a valid API token. In Postman: Collection → Authorization → Type Bearer Token, Token `{{apiToken}}`, and set the `apiToken` collection variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:1337"
    },
    {
      "key": "apiToken",
      "value": ""
    },
    {
      "key": "dishId",
      "value": "1"
    },
    {
      "key": "restaurantId",
      "value": "1"
    },
    {
      "key": "chefId",
      "value": "1"
    },
    {
      "key": "tagId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Dishes",
      "item": [
        {
          "name": "GET /api/dishes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/dishes?populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dishes"],
              "query": [
                {
                  "key": "populate",
                  "value": "*"
                }
              ]
            },
            "description": "List all dishes. `populate=*` includes first-level relations and media."
          }
        },
        {
          "name": "GET /api/dishes/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/dishes/{{dishId}}?populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dishes", "{{dishId}}"],
              "query": [
                {
                  "key": "populate",
                  "value": "*"
                }
              ]
            },
            "description": "Get a single dish by document id. `populate=*` includes first-level relations and media."
          }
        },
        {
          "name": "POST /api/dishes",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"name\": \"Example Dish\",\n    \"description\": \"Optional description\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/dishes?populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dishes"],
              "query": [
                {
                  "key": "populate",
                  "value": "*"
                }
              ]
            },
            "description": "Create a dish. Adjust `data` fields to match your Strapi schema (and relations as id or connect syntax). `populate=*` shapes the created entry in the response."
          }
        },
        {
          "name": "PUT /api/dishes/:id",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"name\": \"Updated Dish Name\",\n    \"description\": \"Updated description\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/dishes/{{dishId}}?populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dishes", "{{dishId}}"],
              "query": [
                {
                  "key": "populate",
                  "value": "*"
                }
              ]
            },
            "description": "Update a dish by id. `populate=*` shapes the updated entry in the response."
          }
        },
        {
          "name": "DELETE /api/dishes/:id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/dishes/{{dishId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dishes", "{{dishId}}"]
            },
            "description": "Delete a dish by id."
          }
        }
      ]
    },
