{
  "info": {
    "name": "Strapi Dishes API",
    "description": "CRUD operations for the Strapi dishes content type.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:1337"
    },
    {
      "key": "dishId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "GET /api/dishes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/dishes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dishes"]
        },
        "description": "List all dishes."
      }
    },
    {
      "name": "GET /api/dishes/:id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/dishes/{{dishId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dishes", "{{dishId}}"]
        },
        "description": "Get a single dish by ID."
      }
    },
    {
      "name": "POST /api/dishes",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": {\n    \"name\": \"Example Dish\",\n    \"description\": \"Optional description\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/dishes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dishes"]
        },
        "description": "Create a new dish. Adjust body fields to match your Strapi dish content-type. Authenticated requests may require a Bearer token in the Authorization header."
      }
    },
    {
      "name": "PUT /api/dishes/:id",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": {\n    \"name\": \"Updated Dish Name\",\n    \"description\": \"Updated description\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/dishes/{{dishId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dishes", "{{dishId}}"]
        },
        "description": "Update an existing dish by ID. Set dishId in collection variables or in the path. Authenticated requests may require a Bearer token."
      }
    },
    {
      "name": "DELETE /api/dishes/:id",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/dishes/{{dishId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dishes", "{{dishId}}"]
        },
        "description": "Delete a dish by ID. Set dishId in collection variables. Typically requires authentication."
      }
    }
  ]
}
