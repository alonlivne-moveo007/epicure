# Strapi base URL (no trailing slash). In Docker, compose sets CMS_URL=http://cms:1337 on the backend service.
CMS_URL=http://localhost:1337

# Optional. If set, Nest sends Authorization: Bearer … on every Strapi request.
# If empty, calls are unauthenticated (enable Public permissions per collection in Strapi).
# After wiping Strapi’s DB/volume, old tokens are invalid — create a new token or clear this.
# Create: Strapi Admin → Settings → API Tokens (read-only is enough for GETs).
# Debug (no secret printed): STRAPI_HTTP_DEBUG=true → logs baseURL + hasToken + tokenLength
STRAPI_API_TOKEN=
