# Epicure frontend — environment template
# ---------------------------------------------------------------------------
# Copy to `.env.local` in this folder (`apps/frontend`) when running
# `nx serve @epicure/frontend` (or similar) **without** Docker Compose.
#
# You do **not** need this file for a normal `docker compose up`: variables are
# injected in `docker-compose.yml` for the `frontend` service.
#
# Next.js loads `.env.local` automatically (see https://nextjs.org/docs/app/building-your-application/configuring/environment-variables).
# ---------------------------------------------------------------------------

# Optional. Server-only base URL for the Nest BFF (Server Components, Route Handlers).
# `getBffBaseUrl()` prefers this over NEXT_PUBLIC_*.
# Use the Docker Compose service hostname when Next runs *inside* the frontend container:
# BFF_INTERNAL_URL=http://backend:3002

# Optional. Used as fallback when `BFF_INTERNAL_URL` is unset.
# Exposed to the browser as well (NEXT_PUBLIC_*); only needed if the BFF is not at localhost:3002
# or you plan client-side calls to the same origin.
# NEXT_PUBLIC_API_URL=http://localhost:3002

# If both are omitted, `getBffBaseUrl()` defaults to http://localhost:3002 — fine for local dev
# with Nest on the default port.
