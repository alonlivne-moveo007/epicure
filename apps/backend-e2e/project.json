{
  "name": "@epicure/backend-e2e",
  "tags": ["type:app", "scope:backend"],
  "implicitDependencies": ["@epicure/backend"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{projectRoot}/test-output/jest/coverage"],
      "options": {
        "jestConfig": "apps/backend-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["@epicure/backend:build", "@epicure/backend:serve"]
    }
  }
}
