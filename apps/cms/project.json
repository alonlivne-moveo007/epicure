{
  "name": "cms",
  "tags": ["type:app", "scope:cms"],
  "targets": {
    "develop": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run develop",
        "cwd": "apps/cms"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "apps/cms"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run start",
        "cwd": "apps/cms"
      }
    }
  }
}
