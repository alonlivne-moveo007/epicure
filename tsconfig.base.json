{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@epicure/source"],
    "paths": {
      "@epicure/mappers": ["libs/shared/mappers/src/index.ts"],
      "@epicure/domain": ["libs/shared/domain/src/index.ts"],
      "@epicure/strapi-dto": ["libs/shared/strapi-dto/src/index.ts"],
      "@epicure/strapi-media": ["libs/shared/strapi-media/src/index.ts"]
    }
  }
}
